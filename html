<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bugamama Reservas</title>

  <style>
    body{
      font-family: Arial, sans-serif;
      background:#f4f4f4;
      margin:0;
      padding:20px;
    }

    .container{
      max-width:500px;
      margin:auto;
      background:white;
      padding:20px;
      border-radius:12px;
      box-shadow:0 0 15px rgba(0,0,0,0.1);
    }

    h2,h3{
      text-align:center;
    }

    input{
      width:100%;
      padding:10px;
      margin:8px 0;
      border-radius:6px;
      border:1px solid #ccc;
    }

    button{
      width:100%;
      padding:12px;
      background:#25D366;
      color:white;
      border:none;
      border-radius:6px;
      font-size:16px;
      cursor:pointer;
    }

    button:hover{
      background:#1ebe5d;
    }

    .mesas{
      display:grid;
      grid-template-columns: repeat(5, 1fr);
      gap:8px;
      margin:15px 0;
    }

    .mesa{
      padding:10px;
      border-radius:8px;
      text-align:center;
      border:2px solid #ccc;
      font-size:14px;
      background:#e9e9e9;
    }

    .ocupada{
      background:#f7d4d4;
      font-weight:bold;
    }

    .libre{
      background:#d4f7d4;
    }
  </style>
</head>
<body>

<div class="container">

  <h2>🍽️ Reservas Bugamama</h2>

  <h3>🪑 Estado de mesas</h3>
  <div id="mesas" class="mesas"></div>

  <input type="text" id="nombre" placeholder="Nombre completo" />
  <input type="tel" id="telefono" placeholder="Teléfono" />
  <input type="date" id="fecha" />
  <input type="number" id="personas" placeholder="Cantidad de personas" />

  <button onclick="reservar()">Reservar por WhatsApp</button>

</div>

<script>
let mesasOcupadas = JSON.parse(localStorage.getItem("mesas")) || {};

function cargarMesas(){
  const contenedor = document.getElementById("mesas");
  contenedor.innerHTML = "";

  for(let i=1;i<=10;i++){
    const div = document.createElement("div");
    div.classList.add("mesa");

    if(mesasOcupadas[i]){
      div.classList.add("ocupada");
      div.innerText = "Mesa " + i + " ❌ Ocupada";
    } else {
      div.classList.add("libre");
      div.innerText = "Mesa " + i + " ✔ Libre";
    }

    contenedor.appendChild(div);
  }
}

function reservar(){
  const nombre = document.getElementById("nombre").value.trim();
  const telefono = document.getElementById("telefono").value.trim();
  const fecha = document.getElementById("fecha").value;
  const personas = document.getElementById("personas").value;

  if(!nombre || !telefono || !fecha || !personas){
    alert("⚠️ Completa todos los campos");
    return;
  }

  const mensaje =
    "🍽️ Nueva Reserva Bugamama\n\n"+
    "👤 Nombre: "+nombre+"\n"+
    "📞 Teléfono: "+telefono+"\n"+
    "📅 Fecha: "+fecha+"\n"+
    "👥 Personas: "+personas;

  const numero = "50234837662";
  const url = "https://wa.me/"+numero+"?text="+encodeURIComponent(mensaje);

  window.open(url,"_blank");

  // NO selección manual: aquí solo simulamos bloqueo automático simple
  for(let i=1;i<=10;i++){
    if(!mesasOcupadas[i]){
      mesasOcupadas[i] = true;
      break;
    }
  }

  localStorage.setItem("mesas", JSON.stringify(mesasOcupadas));
  cargarMesas();
}

cargarMesas();
</script>

</body>
</html>
